# RadSim Configuration
# Copy this to ~/.radsim/.env and fill in your API keys.
# Project-local .env files are not used for RadSim provider config.

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Current CLI options: openrouter, openai, claude
RADSIM_PROVIDER="openrouter"

# =============================================================================
# MODEL SELECTION
# =============================================================================

# Default OpenRouter model
RADSIM_MODEL="moonshotai/kimi-k2.5"

# OpenRouter models listed in main:
#   - moonshotai/kimi-k2.5
#   - anthropic/claude-opus-4.6
#   - anthropic/claude-sonnet-4.6
#   - openai/gpt-5.4
#   - openai/gpt-5.3-codex
#   - openai/gpt-5.2-codex
#   - minimax/minimax-m2.1
#   - z-ai/glm-4.7

# OpenAI models listed in main:
#   - gpt-5.4
#   - gpt-5.3-codex
#   - gpt-5.2
#   - gpt-5.2-codex
#   - gpt-5-mini

# Claude models listed in main:
#   - claude-opus-4-6
#   - claude-sonnet-4-5
#   - claude-haiku-4-5

# =============================================================================
# API KEYS
# =============================================================================
# Add only the keys you use.

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-key-here"

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-key-here"

# Claude (Anthropic) - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="your-anthropic-key-here"

# =============================================================================
# TELEGRAM (Optional)
# =============================================================================

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# =============================================================================
# SECURITY (Optional)
# =============================================================================

# Access code protection. Leave empty to disable.
# RADSIM_ACCESS_CODE="your-access-code"

# =============================================================================
# SECRET EXPIRATION MONITORING (Optional)
# =============================================================================
# Track when your API keys expire to get warnings before they do.
# Format: RADSIM_SECRET_EXPIRY_<NAME>=YYYY-MM-DD
#
# Examples:
# RADSIM_SECRET_EXPIRY_OPENROUTER="2026-12-31"
# RADSIM_SECRET_EXPIRY_OPENAI="2026-12-31"
# RADSIM_SECRET_EXPIRY_ANTHROPIC="2026-12-31"
